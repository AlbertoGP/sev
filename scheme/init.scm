;;; init.scm - Editor initialization and keybindings
;;; Note: command.scm is loaded by C before this file

;; Named commands use symbols for reverse lookup
(set-key! global-keymap "C-q" 'quit)
(set-key! global-keymap "C-e" 'eval-buffer)
(set-key! global-keymap "SPC" 'self-insert)
(set-key! global-keymap "RET" 'newline)
(set-key! global-keymap "TAB" 'insert-tab)
(set-key! global-keymap "BSP" 'delete-backward-char)
(set-key! global-keymap "C-h" 'delete-backward-char)
(set-key! global-keymap "DEL" 'delete-forward-char)
(set-key! global-keymap "UP" 'prev-line)
(set-key! global-keymap "DOWN" 'next-line)
(set-key! global-keymap "LEFT" 'backward-char)
(set-key! global-keymap "RIGHT" 'forward-char)
(set-key! global-keymap "C-TAB" 'tab-next)
(set-key! global-keymap "C-S-TAB" 'tab-prev)
(set-key! global-keymap "C-w" 'pane-close)
(set-key! global-keymap "M-0" 'reset-global-scale)
(set-key! global-keymap "M-=" 'increase-global-scale)
(set-key! global-keymap "M--" 'decrease-global-scale)
(set-key! global-keymap "C-0" 'reset-buffer-scale)
(set-key! global-keymap "C-=" 'increase-buffer-scale)
(set-key! global-keymap "C--" 'decrease-buffer-scale)
(set-key! global-keymap "C-s h" 'split-horizontal)
(set-key! global-keymap "C-s v" 'split-vertical)
(set-key! global-keymap "C-UP" 'pane-navigate-up)
(set-key! global-keymap "C-DOWN" 'pane-navigate-down)
(set-key! global-keymap "C-LEFT" 'pane-navigate-left)
(set-key! global-keymap "C-RIGHT" 'pane-navigate-right)
(set-key! global-keymap "C-S-UP" 'pane-h-split-decrease)
(set-key! global-keymap "C-S-DOWN" 'pane-h-split-increase)
(set-key! global-keymap "C-S-LEFT" 'pane-v-split-decrease)
(set-key! global-keymap "C-S-RIGHT" 'pane-v-split-increase)
(set-key! global-keymap "`" 'clay-debug)


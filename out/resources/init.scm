(set-key! global-keymap "C-q" quit)
(set-key! global-keymap "C-x t" toggle-theme)
(set-key! global-keymap "SPC" self-insert)
(set-key! global-keymap "RET" (lambda () (insert-char #\newline)))
(set-key! global-keymap "TAB" (lambda () (insert-char #\tab)))
(set-key! global-keymap "BSP" (lambda () (delete-char 1)))
(set-key! global-keymap "DEL" (lambda () (delete-char -1)))
(set-key! global-keymap "UP" prev-line)
(set-key! global-keymap "DOWN" next-line)
(set-key! global-keymap "LEFT" (lambda () (move-point -1)))
(set-key! global-keymap "RIGHT" (lambda () (move-point 1)))
(set-key! global-keymap "C-s h" split-horizontal)
(set-key! global-keymap "C-s v" split-vertical)
(set-key! global-keymap "`" clay-debug)

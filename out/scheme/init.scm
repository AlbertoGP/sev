;;; Documentation for C primitives
(set-doc! 'quit 'command "Exit the editor.")
(set-doc! 'self-insert 'command "Insert the character that invoked this command.")
(set-doc! 'eval-buffer 'command "Evaluate the current buffer as Scheme code.")
(set-doc! 'next-line 'command "Move point to the next line.")
(set-doc! 'prev-line 'command "Move point to the previous line.")
(set-doc! 'forward-char 'command "Move point forward one character.")
(set-doc! 'backward-char 'command "Move point backward one character.")
(set-doc! 'newline 'command "Insert a newline at point.")
(set-doc! 'insert-tab 'command "Insert a tab character at point.")
(set-doc! 'delete-backward-char 'command "Delete the character before point.")
(set-doc! 'delete-forward-char 'command "Delete the character after point.")
(set-doc! 'move-point 'command "Move point by COUNT characters.")
(set-doc! 'delete-char 'command "Delete COUNT characters before point.")
(set-doc! 'insert-char 'command "Insert character CH at point.")
(set-doc! 'tab-next 'command "Switch to the next tab.")
(set-doc! 'tab-prev 'command "Switch to the previous tab.")
(set-doc! 'split-horizontal 'command "Split the current pane horizontally.")
(set-doc! 'split-vertical 'command "Split the current pane vertically.")
(set-doc! 'pane-close 'command "Close the current pane.")
(set-doc! 'pane-navigate-up 'command "Navigate to the pane above.")
(set-doc! 'pane-navigate-down 'command "Navigate to the pane below.")
(set-doc! 'pane-navigate-left 'command "Navigate to the pane on the left.")
(set-doc! 'pane-navigate-right 'command "Navigate to the pane on the right.")
(set-doc! 'pane-h-split-increase 'command "Increase horizontal split size.")
(set-doc! 'pane-h-split-decrease 'command "Decrease horizontal split size.")
(set-doc! 'pane-v-split-increase 'command "Increase vertical split size.")
(set-doc! 'pane-v-split-decrease 'command "Decrease vertical split size.")
(set-doc! 'clay-debug 'command "Toggle Clay debug mode.")

;;; Mark commands as interactive

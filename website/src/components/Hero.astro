---
const base = import.meta.env.BASE_URL;
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">
  <canvas id="shader" class="absolute inset-0 w-full h-full"></canvas>
  <div class="relative z-10 flex flex-col items-center gap-10 px-6 text-center">
    <div class="flex items-center gap-3">
      <img
        src={`${base}favicon.svg`}
        alt="sev icon"
        width="150"
        height="150"
        class="select-none"
      />
      <div class="flex flex-col gap-3 items-start">
        <h1 class="text-6xl font-bold tracking-tight text-[var(--ctp-text)]">sev</h1>
        <p class="text-lg text-[var(--ctp-subtext1)] max-w-lg">
          An extensible text editor.
        </p>
      </div>
    </div>

    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="https://github.com/dylancobb/sev"
        target="_blank"
        rel="noopener noreferrer"
        class="px-5 py-2.5 rounded-lg bg-[var(--ctp-surface0)] text-[var(--ctp-text)] hover:bg-[var(--ctp-surface1)] transition-colors"
      >
        View on GitHub
      </a>
      <button
        id="demo-btn"
        class="px-5 py-2.5 rounded-lg bg-[var(--ctp-mauve)] text-[var(--ctp-crust)] font-medium hover:opacity-90 transition-opacity"
      >
        Try the Demo
      </button>
    </div>
  </div>
</section>

<script>
  // ── Domain-Warped Fog ──────────────────────────────────────────
  const FRAG = `
precision highp float;
uniform vec2  u_resolution;
uniform float u_time;

const vec3 BASE   = vec3(0.141, 0.153, 0.227);
const vec3 MAUVE  = vec3(0.776, 0.627, 0.965);
const vec3 MAROON = vec3(0.933, 0.600, 0.627);

float hash(vec2 p) {
  p = fract(p * vec2(127.1, 311.7));
  p += dot(p, p + 19.19);
  return fract(p.x * p.y);
}
float noise(vec2 p) {
  vec2 i = floor(p), f = fract(p);
  vec2 u = f * f * (3.0 - 2.0 * f);
  return mix(mix(hash(i),             hash(i + vec2(1.0, 0.0)), u.x),
             mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), u.x), u.y);
}
float fbm(vec2 p) {
  float v = 0.0, a = 0.5;
  mat2  m = mat2(1.6, 1.2, -1.2, 1.6);
  for (int i = 0; i < 6; i++) { v += a * noise(p); p = m * p; a *= 0.5; }
  return v;
}

void main() {
  vec2  uv = (gl_FragCoord.xy - 0.5 * u_resolution) / u_resolution.y;
  float t  = u_time * 0.047;

  vec2 q = vec2(fbm(uv + vec2(0.0, 0.0) + t),
                fbm(uv + vec2(5.2, 1.3) + t * 0.85));
  vec2 r = vec2(fbm(uv + 1.8 * q + vec2(1.7, 9.2) + t * 0.45),
                fbm(uv + 1.8 * q + vec2(8.3, 2.8) + t * 0.38));
  float f = fbm(uv + 3.0 * r);

  vec3 col = mix(BASE,  MAUVE,  clamp(f * 2.0 - 0.7,         0.0, 1.0));
  col      = mix(col,   MAROON, clamp(length(q) * 0.55,       0.0, 1.0));
  col      = mix(col,   MAUVE, clamp(r.x * r.x * 0.35, 0.0, 1.0));

  float lum = f * f;
  col = col * (lum * 1.5 + 0.15);
  col = mix(BASE, col, smoothstep(0.05, 0.5, lum * 2.5));

  float d = length(gl_FragCoord.xy / u_resolution - 0.5) * 2.0;
  col = mix(col, BASE, smoothstep(0.6, 1.4, d));

  gl_FragColor = vec4(clamp(col, 0.0, 1.0), 1.0);
}`;

  // ── ASCII post-process shader ─────────────────────────────────────────────
  const FRAG_ASCII = `
precision highp float;
uniform sampler2D u_fog;
uniform sampler2D u_chars;
uniform vec2  u_resolution;
uniform vec2  u_cell_size;
uniform float u_char_count;

void main() {
  vec2 cellIdx    = floor(gl_FragCoord.xy / u_cell_size);
  vec2 cellCenter = (cellIdx + 0.5) * u_cell_size / u_resolution;

  vec4  fog  = texture2D(u_fog, cellCenter);
  float luma = dot(fog.rgb, vec3(0.299, 0.587, 0.114));
  float remap = pow(luma, 0.6);

  float ci     = clamp(floor(remap * u_char_count), 0.0, u_char_count - 1.0);
  vec2  local  = fract(gl_FragCoord.xy / u_cell_size);
  float mask   = texture2D(u_chars, vec2((ci + local.x) / u_char_count, local.y)).r;

  vec3 BASE  = vec3(0.141, 0.153, 0.227);
  vec3 color = mix(BASE, fog.rgb, mask);
  gl_FragColor = vec4(mix(BASE, color, 0.33), 1.0);
}`;

  // ── WebGL init (two-pass: fog → FBO → ASCII) ──────────────────────────────
  function initAsciiShader(id: string, fogFrag: string) {
    const canvas = document.getElementById(id) as HTMLCanvasElement | null;
    if (!canvas) return;
    const gl = canvas.getContext('webgl');
    if (!gl) return;

    const VS = `attribute vec2 a_pos; void main(){gl_Position=vec4(a_pos,0.0,1.0);}`;

    const compile = (type: number, src: string) => {
      const s = gl.createShader(type)!;
      gl.shaderSource(s, src);
      gl.compileShader(s);
      if (!gl.getShaderParameter(s, gl.COMPILE_STATUS))
        console.error(gl.getShaderInfoLog(s));
      return s;
    };
    const buildProg = (fSrc: string) => {
      const p = gl.createProgram()!;
      gl.attachShader(p, compile(gl.VERTEX_SHADER, VS));
      gl.attachShader(p, compile(gl.FRAGMENT_SHADER, fSrc));
      gl.linkProgram(p);
      return p;
    };

    const fogProg   = buildProg(fogFrag);
    const asciiProg = buildProg(FRAG_ASCII);

    // Shared fullscreen quad
    gl.bindBuffer(gl.ARRAY_BUFFER, gl.createBuffer());
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
    const bindQuad = (prog: WebGLProgram) => {
      const loc = gl.getAttribLocation(prog, 'a_pos');
      gl.enableVertexAttribArray(loc);
      gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
    };

    // ── Character atlas ───────────────────────────────────────────────────
    const CHARS = "`.'_^;<!c/?LvJ(F{}I1l[eZYja2SqPhdVObAXmR#B0NQ&@";
    const dpr   = devicePixelRatio || 1;
    const CW    = Math.round(8  * dpr);
    const CH    = Math.round(16 * dpr);

    const atlasCvs = document.createElement('canvas');
    atlasCvs.width  = CW * CHARS.length;
    atlasCvs.height = CH;
    const ac = atlasCvs.getContext('2d')!;
    ac.fillStyle = '#000';
    ac.fillRect(0, 0, atlasCvs.width, atlasCvs.height);
    ac.fillStyle = '#fff';
    ac.font = `${CH}px monospace`;
    ac.textAlign    = 'center';
    ac.textBaseline = 'middle';
    for (let i = 0; i < CHARS.length; i++)
      ac.fillText(CHARS[i], (i + 0.5) * CW, CH * 0.5);

    const atlasTex = gl.createTexture()!;
    gl.bindTexture(gl.TEXTURE_2D, atlasTex);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, true);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, atlasCvs);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.NEAREST);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.NEAREST);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);

    // ── Framebuffer ───────────────────────────────────────────────────────
    const fbo = gl.createFramebuffer()!;
    let fboTex = gl.createTexture()!;

    const makeFboTex = (w: number, h: number) => {
      gl.bindTexture(gl.TEXTURE_2D, fboTex);
      gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, w, h, 0, gl.RGBA, gl.UNSIGNED_BYTE, null);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
      gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
      gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, fboTex, 0);
      gl.bindFramebuffer(gl.FRAMEBUFFER, null);
    };

    const resize = () => {
      canvas.width  = canvas.clientWidth  * dpr;
      canvas.height = canvas.clientHeight * dpr;
      gl.deleteTexture(fboTex);
      fboTex = gl.createTexture()!;
      makeFboTex(canvas.width, canvas.height);
      gl.viewport(0, 0, canvas.width, canvas.height);
    };
    new ResizeObserver(resize).observe(canvas);
    resize();

    // ── Uniform locations ─────────────────────────────────────────────────
    const fog_uRes  = gl.getUniformLocation(fogProg,   'u_resolution');
    const fog_uTime = gl.getUniformLocation(fogProg,   'u_time');
    const asc_uFog  = gl.getUniformLocation(asciiProg, 'u_fog');
    const asc_uChr  = gl.getUniformLocation(asciiProg, 'u_chars');
    const asc_uRes  = gl.getUniformLocation(asciiProg, 'u_resolution');
    const asc_uCell = gl.getUniformLocation(asciiProg, 'u_cell_size');
    const asc_uCnt  = gl.getUniformLocation(asciiProg, 'u_char_count');

    // ── Render loop ───────────────────────────────────────────────────────
    const t0 = performance.now();
    const frame = () => {
      const W = canvas.width, H = canvas.height;
      const t = (performance.now() - t0) * 0.001;

      // Pass 1: fog → FBO
      gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
      gl.viewport(0, 0, W, H);
      gl.useProgram(fogProg);
      bindQuad(fogProg);
      gl.uniform2f(fog_uRes, W, H);
      gl.uniform1f(fog_uTime, t);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

      // Pass 2: ASCII → screen
      gl.bindFramebuffer(gl.FRAMEBUFFER, null);
      gl.viewport(0, 0, W, H);
      gl.useProgram(asciiProg);
      bindQuad(asciiProg);
      gl.activeTexture(gl.TEXTURE0);
      gl.bindTexture(gl.TEXTURE_2D, fboTex);
      gl.uniform1i(asc_uFog, 0);
      gl.activeTexture(gl.TEXTURE1);
      gl.bindTexture(gl.TEXTURE_2D, atlasTex);
      gl.uniform1i(asc_uChr, 1);
      gl.uniform2f(asc_uRes,  W, H);
      gl.uniform2f(asc_uCell, CW, CH);
      gl.uniform1f(asc_uCnt,  CHARS.length);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

      if (animating) requestAnimationFrame(frame);
    };

    let animating = false;
    new IntersectionObserver(entries => {
      if (entries[0].isIntersecting && !animating) {
        animating = true;
        requestAnimationFrame(frame);
      } else if (!entries[0].isIntersecting) {
        animating = false;
      }
    }).observe(canvas);
  }

  initAsciiShader('shader', FRAG);
</script>

---
const base = import.meta.env.BASE_URL;
---

<section class="px-6 py-16">
  <div class="max-w-2xl mx-auto flex flex-col gap-8">
    <div class="max-w-2xl flex flex-col gap-6 text-subtext1">
      <h2 class="text-xl sm:text-2xl md:text-3xl font-display text-blue">It runs anywhere</h2>
      <p>
                Sev can build to a desktop executable or to WebAssembly, allowing it to be served directly in the browser.
      </p>
    </div>
    <div class="flex items-center gap-6 justify-center">
      <img src={`${base}C.svg`} alt="C" class="h-10 w-auto object-contain" />
      <svg class="text-overlay1 shrink-0" width="24" height="16" viewBox="0 0 24 16" fill="none">
        <defs>
          <marker id="arr-single" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="4" markerHeight="4" orient="auto">
            <path d="M0,0 L10,5 L0,10 Z" fill="currentColor"/>
          </marker>
        </defs>
        <line x1="0" y1="8" x2="22" y2="8" stroke="currentColor" stroke-width="1.5" marker-end="url(#arr-single)"/>
      </svg>
      <img src={`${base}wasm.svg`} alt="WebAssembly" class="h-10 w-auto object-contain" />
      <svg class="text-overlay1 shrink-0" width="48" height="146" viewBox="0 0 48 146" fill="none">
        <defs>
          <marker id="arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="4" markerHeight="4" orient="auto">
            <path d="M0,0 L10,5 L0,10 Z" fill="currentColor"/>
          </marker>
        </defs>
        <line x1="2" y1="64" x2="46" y2="32"  stroke="currentColor" stroke-width="1.5" marker-end="url(#arr)"/>
        <line x1="2" y1="70" x2="46" y2="59"  stroke="currentColor" stroke-width="1.5" marker-end="url(#arr)"/>
        <line x1="2" y1="76" x2="46" y2="87"  stroke="currentColor" stroke-width="1.5" marker-end="url(#arr)"/>
        <line x1="2" y1="82" x2="46" y2="114" stroke="currentColor" stroke-width="1.5" marker-end="url(#arr)"/>
      </svg>
      <div class="flex flex-col gap-1.5">
        <img src={`${base}chrome.svg`} alt="Chrome" class="h-8 w-auto object-contain" />
        <img src={`${base}firefox.svg`} alt="Firefox" class="h-8 w-auto object-contain" />
        <img src={`${base}edge.svg`} alt="Edge" class="h-8 w-auto object-contain" />
        <img src={`${base}safari.svg`} alt="Safari" class="h-8 w-auto object-contain" />
      </div>
    </div>
  </div>
</section>

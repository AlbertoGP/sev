---
const base = import.meta.env.BASE_URL;
---

<section class="px-6 py-16">
  <div class="max-w-2xl mx-auto flex flex-col gap-6">
    <h2 class="text-2xl font-display text-blue text-center">Join our community</h2>
    <p class="text-subtext1 text-center">
      Join the Discord to follow development, ask questions, or share ideas.
    </p>
    <div class="flex justify-center">
      <a
        href="https://discord.gg/v3gB3bJJ"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[#5865f2] text-text hover:opacity-90 transition-opacity"
      >
        <img src={`${base}discord.svg`} alt="" aria-hidden="true" class="w-5 h-5" />
        Discord
      </a>
    </div>
  </div>
</section>

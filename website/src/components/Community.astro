---
const base = import.meta.env.BASE_URL;
---

<section class="px-6 py-16 bg-mantle">
  <div class="max-w-2xl mx-auto flex flex-col gap-6">
    <h2 class="text-xl sm:text-2xl md:text-3xl font-display text-blue text-center">Join our community</h2>
    <p class="text-subtext1 text-center">
      Join the Discord to follow development, ask questions, or share ideas. Sev is also fully open source, and welcomes your participation in its development.
    </p>
    <div class="flex gap-4 justify-center">
      <a
        href="https://github.com/dylancobb/sev"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-5 py-2.5 rounded-lg bg-surface0 text-text hover:bg-surface1 transition-colors border border-surface2"
      >
        <img src={`${base}github.svg`} alt="" aria-hidden="true" class="w-5 h-5" />
        GitHub
      </a>
      <a
        href="https://discord.gg/v3gB3bJJ"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[#5865f2] text-text hover:opacity-90 transition-opacity"
      >
        <img src={`${base}discord.svg`} alt="" aria-hidden="true" class="w-5 h-5" />
        Discord
      </a>
    </div>
  </div>
</section>
